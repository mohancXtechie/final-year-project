cat > .gitignore << 'EOF'
# Credentials
.env

# Dataset processed outputs
dataset/processed/
dataset/*.csv

# Trained models
models/

# Evidence packages
evidence_packages/

# Python
__pycache__/
*.py[cod]
*.pyo
.Python
*.egg
*.egg-info/
dist/
build/

# Virtual environments
venv/
env/
ENV/
.venv/

# Jupyter
.ipynb_checkpoints
*.ipynb

# IDE
.vscode/
.idea/
*.swp
*~
.DS_Store
Thumbs.db

# TensorFlow
*.h5
*.keras
*.pb

# Logs
*.log
logs/

# Streamlit
.streamlit/

# Pytest
.pytest_cache/
.coverage
EOF